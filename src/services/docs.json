{
  "openapi": "3.0.1",
  "info": {
    "title": "API OCDS",
    "description": "En esta sección puedes encontrar la documentación detallada sobre el uso de la API del Portal de Contrataciones Abiertas de la Compra Pública de Guatemala.\n\n### Documentación de Open Contracting Partnership (OCP) sobre OCDS:\n* [Documentación de referencia del Identificador de Proceso de Contratación (OCID)](https://standard.open-contracting.org/1.1/es/schema/identifiers/#contracting-process-identifier-ocidt)\n* [Documentación de referencia de entregas o releases](https://standard.open-contracting.org/latest/es/schema/reference/)\n* [Documentación de referencia de records o registros](https://standard.open-contracting.org/latest/es/schema/records_reference/)",
    "termsOfService": "https://www.guatecompras.gt/descargas/politica_publicacion.pdf",
    "version": "v1"
  },
  "paths": {
    "/file/{type}/{year}/{month}": {
      "get": {
        "tags": [
          "File"
        ],
        "summary": "Obtiene un archivo de descarga masiva\r\nGET: file/json/2024/01",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "description": "Es el tipo de archivo a descargar",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/TipoArchivo"
            }
          },
          {
            "name": "year",
            "in": "path",
            "description": "Año del archivo",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            },
            "example": 2020
          },
          {
            "name": "month",
            "in": "path",
            "description": "Mes del archivo",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/json": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "text/json": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/MensajeResultadoDeOperacionesModelo"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MensajeResultadoDeOperacionesModelo"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/MensajeResultadoDeOperacionesModelo"
                }
              }
            }
          },
          "204": {
            "description": "Success"
          }
        }
      }
    },
    "/files": {
      "get": {
        "tags": [
          "File"
        ],
        "summary": "Obtiene una lista de archivos de descargas masivas",
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "description": "Año del archivo",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "month",
            "in": "query",
            "description": "Mes del archivo",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FilePkgRecord"
                }
              }
            }
          }
        }
      }
    },
    "/record/{ocid}": {
      "get": {
        "tags": [
          "record"
        ],
        "summary": "Obtiene una lista de RecordPackage",
        "parameters": [
          {
            "name": "ocid",
            "in": "path",
            "description": "Es el identificador del record Default value : <b>ocds-xqjsxa-16024362</b>",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/release/searchNog/{nog}": {
      "get": {
        "tags": [
          "release"
        ],
        "summary": "Obtine el último release, por identificador NOG (Número de operación de Guatecompras)\r\nEjemplo: 16024362",
        "parameters": [
          {
            "name": "nog",
            "in": "path",
            "description": "NOG (Número de operación de Guatecompras)",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HeaderRelease"
                }
              }
            }
          }
        }
      }
    },
    "/release/search": {
      "get": {
        "tags": [
          "release"
        ],
        "summary": "Búsqueda y lista de releases por ciertos criterios, recorrido secuencial (método Search alter) para explorar más de 10,000 resultados",
        "description": "**Tabla de parámetros:**\r\n\r\nParámetro | Descripción | Ejemplo\r\n--------- | ----------- | ----------\r\nanio | Año de la publicacion | 2021\r\nmes | Mes de la publicación | 2 dígitos => 10 (Octubre)\r\ndia | Día de la publicación | 2 dígitos => 25 \r\ntipo_entidad | Tipo de entidad | dígitos\r\nsub_tipo_entidad | Sub tipo de entidad | dígitos\r\nentidad | Entidad compradora | dígitos\r\nunidad_compradora | Unidad compradora | dígitos\r\nmodalidad_compradora | Modalidad de compra | dígitos\r\nsub_modalidad_compradora | Sub modalidad de compra | dígitos\r\nestatus_concurso | Estado de concurso | dígitos\r\n\r\n**Nota:** parámetro de tiempo obligatorio (Año ó Mes ó Día)",
        "parameters": [
          {
            "name": "pagina",
            "in": "query",
            "description": "Obtiene un número de página específica del los Releases o Entregas",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "ordenamiento",
            "in": "query",
            "description": "Ordena los releases por la fecha publicación",
            "schema": {
              "$ref": "#/components/schemas/orderDatePublishNOG"
            }
          },
          {
            "name": "Anio",
            "in": "query",
            "description": "Año de la publicacion",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Mes",
            "in": "query",
            "description": "Mes de la publicación",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Dia",
            "in": "query",
            "description": "Día de la publicación",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Tipo_entidad",
            "in": "query",
            "description": "Tipo de entidad",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Sub_tipo_entidad",
            "in": "query",
            "description": "Sub tipo de entidad",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Entidad",
            "in": "query",
            "description": "Entidad compradora",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Unidad_compradora",
            "in": "query",
            "description": "Unidad compradora",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Modalidad_compradora",
            "in": "query",
            "description": "Modalidad de compra",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Sub_modalidad_compradora",
            "in": "query",
            "description": "Sub modalidad de compra",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Estatus_concurso",
            "in": "query",
            "description": "Estado de concurso",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HeaderRelease"
                }
              }
            }
          }
        }
      }
    },
    "/release/{id}": {
      "get": {
        "tags": [
          "release"
        ],
        "summary": "Obtiene un release por el identificador\r\nEjemplo de un identificador de release:  GT-NOG-17047528-T637979723532777654",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Identificador de release. Ejemplo: GT-NOG-17047528-T637979723532777654",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
